{
  "name": "@borkd/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client",
    "dev:web": "expo start --web",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "build:web": "expo export --platform web --output-dir dist",
    "serve:web": "npx serve dist -l 3002 --single",
    "lint": "biome check app/ components/ features/ lib/ constants/",
    "check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf .expo dist node_modules"
  },
  "dependencies": {
    "@borkd/shared": "workspace:*",
    "@expo/metro-runtime": "~55.0.9",
    "@gorhom/bottom-sheet": "~5.2.0",
    "@hookform/resolvers": "~3.10.0",
    "@rnmapbox/maps": "^10.2.10",
    "@shopify/flash-list": "~1.7.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "~5.75.0",
    "@transistorsoft/background-geolocation-types": "^5.0.1",
    "expo": "~55.0.0",
    "expo-apple-authentication": "^55.0.9",
    "expo-auth-session": "^55.0.9",
    "expo-constants": "~55.0.0",
    "expo-crypto": "^55.0.10",
    "expo-file-system": "~55.0.0",
    "expo-haptics": "~55.0.0",
    "expo-image": "~55.0.0",
    "expo-linking": "~55.0.0",
    "expo-location": "^55.1.4",
    "expo-router": "~55.0.0",
    "expo-secure-store": "~55.0.0",
    "expo-splash-screen": "~55.0.0",
    "expo-status-bar": "~55.0.0",
    "expo-web-browser": "^55.0.10",
    "lucide-react-native": "latest",
    "mapbox-gl": "^3.20.0",
    "moti": "~0.29.0",
    "nativewind": "~4.1.0",
    "posthog-react-native": "^4.41.2",
    "react": "~19.2.0",
    "react-dom": "19.2.4",
    "react-hook-form": "~7.56.0",
    "react-map-gl": "^7.1.9",
    "react-native": "~0.83.0",
    "react-native-background-geolocation": "^5.0.4",
    "react-native-css-interop": "0.1.22",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-mmkv": "~3.2.0",
    "react-native-reanimated": "~3.17.0",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.10.0",
    "react-native-svg": "~15.11.0",
    "react-native-web": "~0.20.0",
    "zod": "~3.23.0",
    "zustand": "~5.0.0"
  },
  "devDependencies": {
    "@expo/config-plugins": "~55.0.0",
    "@types/react": "~19.2.0",
    "tailwindcss": "~3.4.0",
    "typescript": "~5.7.0",
    "vitest": "~3.2.0"
  }
