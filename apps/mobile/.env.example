# Borkd mobile — environment variables
#
# All `EXPO_PUBLIC_*` vars are inlined into the client bundle by Expo — never
# put server-only secrets here. For each scope, use the matching Supabase /
# Mapbox / PostHog project. Values below are illustrative placeholders.
#
# Local development:
#   cp .env.example .env.local
#   fill values from 1Password "Borkd — dev env" or Supabase dashboard
#
# Vercel / EAS / CI: set these in the platform's env var UI, not here.

# ── Supabase ──────────────────────────────────────────────────────────
# Local:      http://127.0.0.1:54321
# Staging:    https://ubkteksfmzxfhsphroog.supabase.co
# Production: https://<PROD_REF>.supabase.co  (TBD — create via dashboard)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Mapbox ────────────────────────────────────────────────────────────
# Use URL-restricted public tokens. Create two in Mapbox dashboard:
#   pk.borkd-staging.* — allowed URLs: localhost, *.vercel.app
#   pk.borkd-prod.*    — allowed URLs: *.borkd.com
EXPO_PUBLIC_MAPBOX_TOKEN=

# ── PostHog (feature flags + analytics) ──────────────────────────────
# Create projects in PostHog Cloud. One project per env:
#   borkd-staging
#   borkd-prod
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Sentry (error monitoring) ─────────────────────────────────────────
# DSN from https://borkd.sentry.io → project `borkd-mobile` → Client Keys.
# Leave empty locally to skip Sentry entirely (SDK becomes a no-op).
# EXPO_PUBLIC_SENTRY_ENV overrides auto-detect (__DEV__ → 'development'
# else 'production'); set to 'preview' / 'staging' in those Vercel scopes.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENV=
