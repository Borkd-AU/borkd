# Supabase staging project — fill in from https://supabase.com/dashboard/project/_/settings/api
# Copy to .env.local (gitignored) before running seed scripts.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# Optional: override for custom seeder identification
# Sent as User-Agent to Nominatim (required by their policy)
NOMINATIM_USER_AGENT=Borkd MVP seeder (ryan@borkd.app)
