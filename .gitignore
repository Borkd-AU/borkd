# Dependencies
node_modules/

# Expo
.expo/

# Build outputs
dist/

# Turborepo
.turbo/

# Environment variables (templates are committed, see exception below)
.env*
*.local
!.env.example
!**/.env.example

# Native builds
ios/
android/

# OS files
.DS_Store

# Test coverage
coverage/

# Claude Code local settings
.claude/settings.local.json
.claude/context/sessions/
