# TypeScript build info
*.tsbuildinfo

# Seed script working files (caches/audit logs — not reproducibility data)
data/seed/manual/.geocoded.json
data/seed/dropped.json

# Supabase CLI local state (auth tokens, branch metadata — machine-specific)
supabase/.branches/
supabase/.temp/

# Next.js build output (admin)
apps/admin/.next/
apps/admin/out/

# EAS build state (mobile) — generated by `eas build` locally
.eas/
apps/mobile/.eas/

