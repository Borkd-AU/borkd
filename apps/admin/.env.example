# Borkd admin — environment variables
#
# `NEXT_PUBLIC_*` vars are inlined into the client bundle. Anything without
# that prefix stays server-side (Next.js server components, route handlers,
# Server Actions) — use these for `SUPABASE_SERVICE_ROLE_KEY` and similar.
#
# Local development:
#   cp .env.example .env.local
#   fill values from 1Password "Borkd — dev env"
#
# Vercel / CI: set these in the platform's env var UI, not here.

# ── Supabase (client-safe) ────────────────────────────────────────────
# Local:      http://127.0.0.1:54321
# Staging:    https://ubkteksfmzxfhsphroog.supabase.co
# Production: https://<PROD_REF>.supabase.co  (TBD)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase service role (SERVER ONLY — never expose to client) ─────
# Bypasses RLS. Used by admin Server Actions for moderation tools.
# Rotate on suspicion; store only in Vercel Production + Preview env.
SUPABASE_SERVICE_ROLE_KEY=

# ── Mapbox (for admin pin map / walk heatmaps) ────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── PostHog ──────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Sentry (error monitoring) ─────────────────────────────────────────
# DSN from https://borkd.sentry.io → project `borkd-admin` → Client Keys.
# Same DSN is read by sentry.client.config.ts, sentry.server.config.ts,
# and sentry.edge.config.ts. Leave empty locally to skip Sentry.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=
# Server-only override (doesn't get inlined into client bundle).
SENTRY_ENV=

# ── Sentry source-map upload (CI only) ───────────────────────────────
# Read by Next.js plugin during `next build` to upload source maps.
# Set in Vercel env (all scopes) + GitHub Actions secrets.
# Do NOT prefix with NEXT_PUBLIC — keep server-side.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=borkd
SENTRY_PROJECT=borkd-admin
